{
  # Keep any existing global options (logging, ACME email, import, etc.)
}

# Frontend only (do NOT use a wildcard, so api.tilt-us.com is untouched)
tilt-us.com {
  # production: serve the Angular build artifacts directly from disk (no Angular runtime needed)
  root * /srv/mira/website/browser
  try_files {path} /index.html
  file_server
}

# API block is managed separately in the main Caddy config and must remain unchanged:
# api.tilt-us.com {
#   reverse_proxy <your-api-upstream>:<port>
# }

# Optional redirect keeps old host behavior consistent.
www.tilt-us.com {
  redir https://tilt-us.com{uri} 302
}
